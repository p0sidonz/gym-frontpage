# Same Supabase project as the main Vite app (NEXT_PUBLIC_* is exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Razorpay (same as VITE_RAZORPAY_KEY_ID in the main app).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx

# App origin for auth and checkout redirects — e.g. https://my.yourdomain.com
# Log in / Register / checkout will use this host.
NEXT_PUBLIC_APP_URL=https://my.yourdomain.com

# Razorpay webhooks (POST /razor-hook on this Next app) — server-only
RAZORPAY_WEBHOOK_SECRET=whsec_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
